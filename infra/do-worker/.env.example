# Copy to .env on the droplet and fill in.
# .env MUST never be committed.

# Random token used to authenticate clients connecting to Browserless via CDP.
# Generate: openssl rand -hex 32
BROWSERLESS_TOKEN=replace-with-32-byte-hex

# Public domain pointed at the Droplet's IP via A-record.
# Caddy will automatically provision a Let's Encrypt cert for it.
# Example: worker.careerpilot.app
WORKER_DOMAIN=worker.example.com

# Two virtual hosts, both on the same Droplet, both with auto-TLS via Let's Encrypt.
# nip.io handles the DNS: any subdomain under the IP-dashed host resolves to that IP.

{$WORKER_DOMAIN} {
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websocket browserless:3000
	reverse_proxy browserless:3000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}
}

{$FLOWISE_DOMAIN} {
	# Flowise ships its own WebSocket (for streaming tokens) + REST API
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websocket flowise:3100
	reverse_proxy flowise:3100

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}
}

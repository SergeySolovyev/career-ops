# ============================================
# CareerPilot — Environment Configuration
# Copy to .env.local (Next.js) or .env (jobs)
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Anthropic (AI evaluation + cover letters) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Trigger.dev (background jobs) ---
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Telegram Bot (criterion 4) ---
# 1. Create bot: https://t.me/BotFather → /newbot
# 2. Get chat ID: https://t.me/userinfobot → /start
# 3. Setup webhook after deploy: GET /api/telegram/setup?url=https://yourapp.vercel.app
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
